// ================================================================
//  ROBOT TOUR — Arduino Uno R4 WiFi + DRI0041 + FIT0186 + BNO055
//  v7.1 — Absolute heading tracking (no error accumulation)
//         Encoder straight (v5.3) + Encoder turns w/ BNO055 fine
//         LEFT:  Motor B (10/11/12), fwd=IN3 LOW IN4 HIGH, enc pin 2
//         RIGHT: Motor A (9/7/8),   fwd=IN1 LOW IN2 HIGH, enc pin 3
// ================================================================

#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BNO055.h>

Adafruit_BNO055 bno = Adafruit_BNO055(55, 0x28);
float lastGoodHeading = 0.0f;
float missionHeading  = 0.0f;  // Where robot SHOULD be facing

// === Physical Constants ===
#define COUNTS_PER_REV     550.0f
#define WHEEL_DIAMETER_CM  12.4f
#define WHEELBASE_CM       18.5f

// === Encoder turn calibration ===
#define TURN_COUNTS_PER_DEG  2.3f
#define TURN_ENCODER_FRACTION 0.95f

// === Straight-line Speed (v5.3 exact) ===
#define MAX_SPEED      30
#define MIN_SPEED      25
#define CRAWL_SPEED    18
#define RAMP_COUNTS    300
#define CRAWL_COUNTS   350

// === Encoder Differential (v5.3 exact) ===
#define DIFF_KP        1.5f
#define DIFF_DEADBAND  2
#define DIFF_STOP_MAX  5

// === Turn Speed ===
#define TURN_MAX_SPEED   35
#define TURN_MIN_SPEED   24
#define TURN_CRAWL_SPEED 20
#define TURN_RAMP_COUNTS 80
#define TURN_DECEL_COUNTS 120

// === BNO055 fine correction ===
#define FINE_TURN_SPEED    20
#define TURN_TOLERANCE     1.5f

// === Post-move heading correction ===
#define HEADING_FIX_THRESHOLD  2.0f

// === Pins (verified by diagnostic) ===
#define MOTOR_A_ENA  9
#define MOTOR_A_IN1  7
#define MOTOR_A_IN2  8

#define MOTOR_B_ENB  10
#define MOTOR_B_IN3  11
#define MOTOR_B_IN4  12

#define ENC_LEFT_PIN   2
#define ENC_RIGHT_PIN  3

volatile long encLeft  = 0;
volatile long encRight = 0;

void isrLeft()  { encLeft++;  }
void isrRight() { encRight++; }

// ================================================================
//  BNO055 HEADING
// ================================================================

float getHeading() {
  for (int attempt = 0; attempt < 5; attempt++) {
    sensors_event_t event;
    bno.getEvent(&event);
    if (event.orientation.x != 0.0f ||
        event.orientation.y != 0.0f ||
        event.orientation.z != 0.0f) {
      lastGoodHeading = event.orientation.x;
      return event.orientation.x;
    }
    delayMicroseconds(500);
  }
  return lastGoodHeading;
}

float getReliableHeading() {
  int goodCount = 0;
  float confirmed = 0;
  unsigned long timeout = millis() + 1000;

  while (goodCount < 3 && millis() < timeout) {
    sensors_event_t event;
    bno.getEvent(&event);

    if (event.orientation.x == 0.0f &&
        event.orientation.y == 0.0f &&
        event.orientation.z == 0.0f) {
      delayMicroseconds(500);
      continue;
    }

    float h = event.orientation.x;

    if (goodCount == 0) {
      confirmed = h;
      goodCount = 1;
    } else {
      float diff = confirmed - h;
      if (diff > 180.0f)  diff -= 360.0f;
      if (diff < -180.0f) diff += 360.0f;

      if (abs(diff) < 2.0f) {
        goodCount++;
      } else {
        confirmed = h;
        goodCount = 1;
      }
    }
    delay(5);
  }

  if (goodCount >= 3) {
    lastGoodHeading = confirmed;
    return confirmed;
  }

  return getHeading();
}

void settle() {
  motorsBrake();
  delay(500);
  lastGoodHeading = getReliableHeading();
  delay(200);
}

float angleDiff(float target, float current) {
  float diff = target - current;
  while (diff > 180.0f)  diff -= 360.0f;
  while (diff < -180.0f) diff += 360.0f;
  return diff;
}

float normalizeAngle(float angle) {
  while (angle < 0.0f)    angle += 360.0f;
  while (angle >= 360.0f) angle -= 360.0f;
  return angle;
}

// ================================================================
//  MOTOR CONTROL (verified by diagnostic)
// ================================================================

void setMotors(int leftSpeed, int rightSpeed) {
  if (leftSpeed >= 0) {
    digitalWrite(MOTOR_B_IN3, LOW);
    digitalWrite(MOTOR_B_IN4, HIGH);
  } else {
    digitalWrite(MOTOR_B_IN3, HIGH);
    digitalWrite(MOTOR_B_IN4, LOW);
    leftSpeed = -leftSpeed;
  }
  analogWrite(MOTOR_B_ENB, constrain(leftSpeed, 0, 255));

  if (rightSpeed >= 0) {
    digitalWrite(MOTOR_A_IN1, LOW);
    digitalWrite(MOTOR_A_IN2, HIGH);
  } else {
    digitalWrite(MOTOR_A_IN1, HIGH);
    digitalWrite(MOTOR_A_IN2, LOW);
    rightSpeed = -rightSpeed;
  }
  analogWrite(MOTOR_A_ENA, constrain(rightSpeed, 0, 255));
}

void motorsBrake() {
  analogWrite(MOTOR_A_ENA, 0);
  analogWrite(MOTOR_B_ENB, 0);
  digitalWrite(MOTOR_A_IN1, LOW);
  digitalWrite(MOTOR_A_IN2, LOW);
  digitalWrite(MOTOR_B_IN3, LOW);
  digitalWrite(MOTOR_B_IN4, LOW);
}

// ================================================================
//  GENTLE STOP (v5.3 exact)
// ================================================================

void gentleStop() {
  for (int pwm = CRAWL_SPEED; pwm >= 0; pwm -= 1) {
    long encDiff = encLeft - encRight;
    if (abs(encDiff) < DIFF_DEADBAND) encDiff = 0;
    int correction = constrain(
      (int)(DIFF_KP * encDiff), -DIFF_STOP_MAX, DIFF_STOP_MAX);

    int leftPWM  = constrain(pwm - correction, 0, 255);
    int rightPWM = constrain(pwm + correction, 0, 255);

    analogWrite(MOTOR_B_ENB, leftPWM);
    analogWrite(MOTOR_A_ENA, rightPWM);
    delay(25);
  }

  motorsBrake();
  delay(100);
}

// ================================================================
//  TURN STOP
// ================================================================

void turnStop() {
  for (int pwm = TURN_CRAWL_SPEED; pwm >= 0; pwm -= 1) {
    analogWrite(MOTOR_A_ENA, pwm);
    analogWrite(MOTOR_B_ENB, pwm);
    delay(15);
  }
  motorsBrake();
  delay(100);
}

// ================================================================
//  DELAY HELPER
// ================================================================

void d(float seconds) {
  delay((unsigned long)(seconds * 1000.0f));
}

// ================================================================
//  SPEED PROFILE — straight (v5.3 exact)
// ================================================================

int rampedSpeed(long encAvg, long target) {
  long remaining = target - encAvg;

  if (remaining < CRAWL_COUNTS) {
    float t = sin(((float)remaining / CRAWL_COUNTS) * (PI / 2.0f));
    return (int)(CRAWL_SPEED + (MAX_SPEED - CRAWL_SPEED) * t);
  }

  if (encAvg < RAMP_COUNTS) {
    float t = sin(((float)encAvg / RAMP_COUNTS) * (PI / 2.0f));
    return (int)(MIN_SPEED + (MAX_SPEED - MIN_SPEED) * t);
  }

  return MAX_SPEED;
}

// ================================================================
//  SPEED PROFILE — encoder turns
// ================================================================

int turnRampedSpeed(long encAvg, long target) {
  long remaining = target - encAvg;

  if (remaining < TURN_DECEL_COUNTS) {
    float t = (float)remaining / TURN_DECEL_COUNTS;
    return (int)(TURN_CRAWL_SPEED + (TURN_MAX_SPEED - TURN_CRAWL_SPEED) * t);
  }

  if (encAvg < TURN_RAMP_COUNTS) {
    float t = (float)encAvg / TURN_RAMP_COUNTS;
    return (int)(TURN_MIN_SPEED + (TURN_MAX_SPEED - TURN_MIN_SPEED) * t);
  }

  return TURN_MAX_SPEED;
}

long distToCounts(float cm) {
  return (long)((cm / (PI * WHEEL_DIAMETER_CM)) * COUNTS_PER_REV);
}

// ================================================================
//  HEADING CORRECTION — corrects to missionHeading (absolute)
// ================================================================

void fixHeading() {
  delay(300);
  float err = angleDiff(missionHeading, getReliableHeading());
  if (abs(err) < HEADING_FIX_THRESHOLD) return;

  unsigned long timeout = millis() + 2000;
  while (millis() < timeout) {
    err = angleDiff(missionHeading, getHeading());
    if (abs(err) < 1.0f) break;

    if (err > 0)
      setMotors(FINE_TURN_SPEED, -FINE_TURN_SPEED);
    else
      setMotors(-FINE_TURN_SPEED, FINE_TURN_SPEED);

    delay(20);
  }
  motorsBrake();
  delay(100);
}

// ================================================================
//  FWD (v5.3 exact + absolute heading correction)
// ================================================================

void fwd(float cm) {
  long target = distToCounts(cm);
  encLeft = 0;
  encRight = 0;

  while (((encLeft + encRight) / 2) < target) {
    long avg = (encLeft + encRight) / 2;
    int baseSpeed = rampedSpeed(avg, target);

    long encDiff = encLeft - encRight;
    if (abs(encDiff) < DIFF_DEADBAND) encDiff = 0;
    int correction = (int)(DIFF_KP * encDiff);

    int leftPWM  = constrain(baseSpeed - correction, MIN_SPEED, MAX_SPEED);
    int rightPWM = constrain(baseSpeed + correction, MIN_SPEED, MAX_SPEED);

    setMotors(leftPWM, rightPWM);
  }

  gentleStop();
  fixHeading();
  settle();
}

// ================================================================
//  REV (v5.3 exact + absolute heading correction)
// ================================================================

void rev(float cm) {
  long target = distToCounts(cm);
  encLeft = 0;
  encRight = 0;

  while (((encLeft + encRight) / 2) < target) {
    long avg = (encLeft + encRight) / 2;
    int baseSpeed = rampedSpeed(avg, target);

    long encDiff = encLeft - encRight;
    if (abs(encDiff) < DIFF_DEADBAND) encDiff = 0;
    int correction = (int)(DIFF_KP * encDiff);

    int leftPWM  = constrain(baseSpeed - correction, MIN_SPEED, MAX_SPEED);
    int rightPWM = constrain(baseSpeed + correction, MIN_SPEED, MAX_SPEED);

    setMotors(-leftPWM, -rightPWM);
  }

  gentleStop();
  fixHeading();
  settle();
}

// ================================================================
//  TURNS — Encoder bulk + BNO055 fine to ABSOLUTE heading
// ================================================================

void turnToHeading(float targetHeading, float totalDeg) {
  targetHeading = normalizeAngle(targetHeading);

  // PHASE 1: Encoder bulk (95%)
  float encoderDeg = abs(totalDeg) * TURN_ENCODER_FRACTION;
  long encoderTarget = (long)(encoderDeg * TURN_COUNTS_PER_DEG);
  encLeft = 0;
  encRight = 0;

  int direction = (totalDeg > 0) ? 1 : -1;

  while (((encLeft + encRight) / 2) < encoderTarget) {
    long avg = (encLeft + encRight) / 2;
    int spd = turnRampedSpeed(avg, encoderTarget);
    setMotors(direction * spd, -direction * spd);
  }

  // PHASE 2: Stop + clean heading read
  turnStop();
  delay(300);
  getReliableHeading();

  // PHASE 3: BNO055 fine correction to ABSOLUTE target
  unsigned long timeout = millis() + 3000;
  while (millis() < timeout) {
    float error = angleDiff(targetHeading, getHeading());
    if (abs(error) < TURN_TOLERANCE) break;

    if (error > 0)
      setMotors(FINE_TURN_SPEED, -FINE_TURN_SPEED);
    else
      setMotors(-FINE_TURN_SPEED, FINE_TURN_SPEED);

    delay(20);
  }

  motorsBrake();
  settle();
}

// right/left update missionHeading mathematically — no measurement error
void right(float deg) {
  missionHeading = normalizeAngle(missionHeading + deg);
  turnToHeading(missionHeading, deg);
}

void left(float deg) {
  missionHeading = normalizeAngle(missionHeading - deg);
  turnToHeading(missionHeading, -deg);
}

// ================================================================
//  MISSION
// ================================================================

void runMission() {
  fwd(50);
  d(1);
  right(90);
  d(1);
  fwd(50);
}

// ================================================================
//  SETUP
// ================================================================

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("Robot Tour v7.1");

  pinMode(MOTOR_A_IN1, OUTPUT);
  pinMode(MOTOR_A_IN2, OUTPUT);
  pinMode(MOTOR_B_IN3, OUTPUT);
  pinMode(MOTOR_B_IN4, OUTPUT);
  pinMode(MOTOR_A_ENA, OUTPUT);
  pinMode(MOTOR_B_ENB, OUTPUT);

  pinMode(ENC_LEFT_PIN, INPUT_PULLUP);
  pinMode(ENC_RIGHT_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(ENC_LEFT_PIN), isrLeft, RISING);
  attachInterrupt(digitalPinToInterrupt(ENC_RIGHT_PIN), isrRight, RISING);

  motorsBrake();

  Wire.begin();

  bool connected = false;
  for (int i = 1; i <= 10; i++) {
    Wire.setClock(50000);
    if (bno.begin()) {
      connected = true;
      break;
    }
    delay(500);
  }

  if (!connected) {
    Serial.println("BNO055 FAILED!");
    while (1) delay(100);
  }

  Wire.setClock(50000);
  bno.setExtCrystalUse(true);
  delay(1000);

  settle();
  missionHeading = lastGoodHeading;  // Lock starting heading

  Serial.println("Mission in 5 sec...");
  delay(5000);
  runMission();
  motorsBrake();
  Serial.println("Done.");
}

void loop() {}

// ================================================================
//  FWD — encoder PD wheel match + IMU heading correction
//
//  Encoder PD: keeps wheels spinning at same rate
//  IMU P: keeps robot pointed at missionHeading
//  Both run every iteration, summed into one steering value
// ================================================================

void fwd(float cm) {
  cm = 5669.521 + (-0.3394784 - 5669.521) / (1 + pow(cm / 4272.084, 1.066098));
  cm = (0.995169f * cm) - 1.09238;
  cm = (0.99905f * cm) - 0.67375f;
  long target = cmToCounts(cm);
  resetEncoders();

  long prevDiff = 0;

  Serial.print("fwd ");
  Serial.print(cm);
  Serial.println(" cm");

  while (((encLeft + encRight) / 2) < target) {
    long avg = (encLeft + encRight) / 2;
    int speed = driveSpeed(avg, target);

    // --- Encoder PD: match wheel speeds ---
    long diff = encLeft - encRight;
    long diffRate = diff - prevDiff;
    prevDiff = diff;
    float enc_correction = ENC_KP * diff + ENC_KD * diffRate;

    // --- IMU P: hold heading ---
    float hdgError = angleDiffAuto(missionHeading, getHeading());
    float hdg_correction = HDG_KP * hdgError;

    // Combine: both corrections steer same way
    // enc_correction > 0 means left ahead, need to slow left = steer left
    // hdg_correction > 0 means need to turn CW = steer right
    // So enc subtracts, hdg adds
    int steering = constrain((int)(-enc_correction + hdg_correction), -STEER_CLAMP, STEER_CLAMP);

    int leftPWM  = constrain(speed + steering, MIN_SPEED, DRIVE_SPEED);
    int rightPWM = constrain(speed - steering, MIN_SPEED, DRIVE_SPEED);

    setMotors(leftPWM, rightPWM);
  }

  smoothStop(1);

  Serial.print("  encL=");
  Serial.print(encLeft);
  Serial.print(" encR=");
  Serial.println(encRight);

  headingCheck();
}

// ================================================================
//  REV — same architecture as fwd, negated drive
//
//  In reverse, steering geometry flips:
//    left faster backward = robot turns LEFT (opposite of fwd)
//  So we negate the steering when applying to motors
// ================================================================

void rev(float cm) {
  // Quartic Regression curve fit
  cm = (((9.67846e-9 * cm - 0.000008565) * cm + 0.0021339) * cm + 0.875267) * cm - 1.46044;
  // Linear regression curve fit for REVERSE (tested 4/10/2026)
  cm = (1.0009f * cm) - 0.376f;
  long target = cmToCounts(cm);
  resetEncoders();

  long prevDiff = 0;

  Serial.print("rev ");
  Serial.print(cm);
  Serial.println(" cm");

  while (abs((encLeft + encRight) / 2) < target) {
    long avg = abs((encLeft + encRight) / 2);
    int speed = driveSpeed(avg, target);

    // --- Encoder PD: match wheel speeds (use abs since both negative) ---
    long diff = abs(encLeft) - abs(encRight);
    long diffRate = diff - prevDiff;
    prevDiff = diff;
    float enc_correction = ENC_KP * diff + ENC_KD * diffRate;

    // --- IMU P: hold heading ---
    float hdgError = angleDiffAuto(missionHeading, getHeading());
    float hdg_correction = HDG_KP * hdgError;

    // Same steering calculation as fwd
    int steering = constrain((int)(-enc_correction + hdg_correction), -STEER_CLAMP, STEER_CLAMP);

    // NEGATE steering for reverse geometry
    int leftPWM  = constrain(speed + steering, MIN_SPEED, DRIVE_SPEED);
    int rightPWM = constrain(speed - steering, MIN_SPEED, DRIVE_SPEED);

    setMotors(-leftPWM, -rightPWM);
  }

  smoothStop(-1);

  Serial.print("  encL=");
  Serial.print(encLeft);
  Serial.print(" encR=");
  Serial.println(encRight);

  headingCheck();
}

// ================================================================
//  TURNS — encoder speed + IMU exit
//
//  Encoder: controls speed profile (fast start, smooth decel)
//  IMU: controls when to stop (within 1 degree of target)
//  headingCheck: PID fine-tunes to 0.25 degree after stopping
// ================================================================

void turnToHeading(float targetHeading, int direction, float degrees) {
  targetHeading = normalizeAngle(targetHeading);
  long turnTarget = (long)(COUNTS_PER_DEGREE * degrees);

  resetEncoders();

  headingCheck();
}

void turnToHeadingCan(float targetHeading, int direction, float degrees) {
  targetHeading = normalizeAngle(targetHeading);
  long turnTarget = (long)(COUNTS_PER_DEGREE * degrees);

  resetEncoders();

  headingCheckCan();
}

void right(float deg) {
  missionHeading = normalizeAngle(missionHeading + deg);
  turnToHeading(missionHeading, 1, deg);
}

void left(float deg) {
  missionHeading = normalizeAngle(missionHeading - deg);
  turnToHeading(missionHeading, -1, deg);
}

void rightC(float deg) {
  missionHeading = normalizeAngle(missionHeading + deg);
  turnToHeadingCan(missionHeading, 1, deg);
}

void leftC(float deg) {
  missionHeading = normalizeAngle(missionHeading - deg);
  turnToHeadingCan(missionHeading, -1, deg);
}


// ================================================================
//  MISSION
// ================================================================

void runMission() {
  fwd(25);
  left(90);
  fwd(100);
  leftC(180);
  fwd(55);
  rev(5);
  left(90);
  fwd(100);
  left(90);
  fwd(50);
  rightC(90);
  fwd(30);
  rev(60);
  fwd(30);
  right(90);
  fwd(100);
  left(90);
  fwd(50);
  leftC(90);
  fwd(50);
  rightC(90);
  rev(50);
  right(90);
  fwd(100);
  right(90);
  fwd(50);
  left(90);
  fwd(35);
  rightC(180);
  fwd(35);
  rightC(90);
  fwd(100);
  rightC(90);
  fwd(50);
  rev(50);
  right(90);
  fwd(100);

  }

// ================================================================
//  SETUP
// ================================================================

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("Robot Tour v14.0 — Encoder+IMU Fusion");

  pinMode(MOTOR_A_IN1, OUTPUT);
  pinMode(MOTOR_A_IN2, OUTPUT);
  pinMode(MOTOR_B_IN3, OUTPUT);
  pinMode(MOTOR_B_IN4, OUTPUT);
  pinMode(MOTOR_A_ENA, OUTPUT);
  pinMode(MOTOR_B_ENB, OUTPUT);

  pinMode(ENC_LEFT_PIN, INPUT_PULLUP);
  pinMode(ENC_RIGHT_PIN, INPUT_PULLUP);
  pinMode(18, INPUT_PULLUP);
  pinMode(19, INPUT_PULLUP);

  attachInterrupt(digitalPinToInterrupt(ENC_LEFT_PIN), isrLeft, CHANGE);
  attachInterrupt(digitalPinToInterrupt(ENC_RIGHT_PIN), isrRight, CHANGE);

  stopMotors();

  Wire.begin();
  if (!bno.begin()) {
    Serial.println("BNO055 FAILED!");
    while (1) delay(100);
  }

  bno.setExtCrystalUse(true);
  delay(1000);

  waitForCalibration();

  missionHeading = getHeading();
  Serial.print("Start heading: ");
  Serial.println(missionHeading);

  Serial.println("Mission in 3 sec...");
  delay(3000);
  runMission();
  stopMotors();
  Serial.println("Done.");
}

